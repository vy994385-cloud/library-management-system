# Library Management System
# Features: Add, View, Search, Issue, Return, Delete, Available Books

class Book:
    def __init__(self, book_id, book_name, author):
        self.book_id = book_id
        self.book_name = book_name
        self.author = author
        self.is_available = True

    def display(self):
        status = "Available" if self.is_available else "Issued"
        print(f"Book ID   : {self.book_id}")
        print(f"Book Name : {self.book_name}")
        print(f"Author    : {self.author}")
        print(f"Status    : {status}")
        print("-" * 30)


class Library:
    def __init__(self):
        self.books = []

    # Add a new book
    def add_book(self):
        try:
            book_id = int(input("Enter Book ID: "))
        except ValueError:
            print("Invalid ID! Please enter a number.")
            return
        for b in self.books:
            if b.book_id == book_id:
                print("Book ID already exists!")
                return
        book_name = input("Enter Book Name: ")
        author = input("Enter Author Name: ")
        self.books.append(Book(book_id, book_name, author))
        print("Book added successfully!")

    # View all books
    def view_books(self):
        if not self.books:
            print("No books in the library.")
            return
        print("\n---- All Books ----")
        for book in self.books:
            book.display()

    # Search book by ID
    def search_book(self):
        try:
            book_id = int(input("Enter Book ID to search: "))
        except ValueError:
            print("Invalid ID!")
            return
        for book in self.books:
            if book.book_id == book_id:
                print("\nBook Found!")
                book.display()
                return
        print("Book not found.")

    # Issue a book
    def issue_book(self):
        try:
            book_id = int(input("Enter Book ID to issue: "))
        except ValueError:
            print("Invalid ID!")
            return
        for book in self.books:
            if book.book_id == book_id:
                if book.is_available:
                    book.is_available = False
                    print(f"'{book.book_name}' issued successfully!")
                else:
                    print("Book is already issued.")
                return
        print("Book not found.")

    # Return a book
    def return_book(self):
        try:
            book_id = int(input("Enter Book ID to return: "))
        except ValueError:
            print("Invalid ID!")
            return
        for book in self.books:
            if book.book_id == book_id:
                if not book.is_available:
                    book.is_available = True
                    print(f"'{book.book_name}' returned successfully!")
                else:
                    print("Book was not issued.")
                return
        print("Book not found.")

    # Delete a book record
    def delete_book(self):
        try:
            book_id = int(input("Enter Book ID to delete: "))
        except ValueError:
            print("Invalid ID!")
            return
        for book in self.books:
            if book.book_id == book_id:
                self.books.remove(book)
                print("Book deleted successfully!")
                return
        print("Book not found.")

    # Display only available books
    def available_books(self):
        available = [book for book in self.books if book.is_available]
        if not available:
            print("No books are currently available.")
            return
        print("\n---- Available Books ----")
        for book in available:
            book.display()

    # Count total, issued, available
    def book_summary(self):
        total = len(self.books)
        issued = len([b for b in self.books if not b.is_available])
        available = total - issued
        print("\n---- Library Summary ----")
        print(f"Total Books     : {total}")
        print(f"Available Books : {available}")
        print(f"Issued Books    : {issued}")


# Main program
library = Library()

while True:
    print("\n==== LIBRARY MANAGEMENT SYSTEM ====")
    print("1. Add Book")
    print("2. View All Books")
    print("3. Search Book")
    print("4. Issue Book")
    print("5. Return Book")
    print("6. Delete Book")
    print("7. View Available Books")
    print("8. Library Summary")
    print("9. Exit")

    try:
        choice = int(input("Enter your choice: "))
    except ValueError:
        print("Invalid input! Please enter a number.")
        continue

    if choice == 1:
        library.add_book()
    elif choice == 2:
        library.view_books()
    elif choice == 3:
        library.search_book()
    elif choice == 4:
        library.issue_book()
    elif choice == 5:
        library.return_book()
    elif choice == 6:
        library.delete_book()
    elif choice == 7:
        library.available_books()
    elif choice == 8:
        library.book_summary()
    elif choice == 9:
        print("Thank You!")
        break
    else:
        print("Invalid choice! Try again.")